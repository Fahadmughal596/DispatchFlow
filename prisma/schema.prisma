generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  TRUCKER
  CONSULTANT_DISPATCHER
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum TruckerStatus {
  LEAD
  ACTIVE
  SUSPENDED
}

enum LeadStatus {
  LEAD_SIGNED_UP
  LEAD_ASSIGNED
  CONTACT_MADE
  CONTRACT_MADE
  PENDING_INVOICE
  INVOICE_SENT
  INVOICE_PAID
}

enum DocumentStatus {
  REQUESTED
  UPLOADED
  APPROVED
  REJECTED
  REPLACEMENT_REQUESTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  VIEWED
  UNPAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

enum LoadStatus {
  DRAFT
  OFFERED
  ASSIGNED
  BOOKED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  DROPPED_OFF
  DOCS_PENDING
  COMPLETED
  CANCELLED
}

enum BillingMethod {
  FIXED
  PERCENTAGE
}

enum AttachmentKind {
  IMAGE
  DOCUMENT
}

model User {
  id                Int       @id @default(autoincrement())
  role              Role
  name              String
  email             String    @unique
  phone             String?
  passwordHash      String?
  googleSubject     String?     @unique
  authProvider      String      @default("EMAIL")
  status            UserStatus @default(ACTIVE)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions          Session[]
  truckerProfile    TruckerProfile?
  consultantProfile ConsultantProfile?
  sentMessages      Message[] @relation("MessageSender")
  messageAttachments MessageAttachment[] @relation("MessageAttachmentUploader")
  uploadedDocuments Document[] @relation("DocumentUploader")
  reviewedDocuments Document[] @relation("DocumentReviewer")
  requestedDocuments DocumentRequest[] @relation("DocumentRequester")
  createdInvoices   Invoice[] @relation("InvoiceConsultant")
  createdLoads      Load[] @relation("LoadConsultant")
  notifications     Notification[]
  auditLogs         AuditLog[] @relation("AuditActor")
  assignedTruckers  TruckerProfile[] @relation("AssignedConsultant")
  assignedLeads     Lead[] @relation("AssignedLeadConsultant")
  consultantConversations Conversation[] @relation("ConversationConsultant")
  uploadedLoadDocuments LoadDocument[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ConsultantProfile {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  bio              String?  @db.Text
  specialty        String?
  workingHours     String?
  timeZone         String?
  isPaused         Boolean  @default(false)
  priorityWeight   Int      @default(1)
  maxLeadCap       Int      @default(100)
  sequencePosition Int      @default(0)
  commissionRateBps Int     @default(500)
  profileCompletedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TruckerProfile {
  id                    Int           @id @default(autoincrement())
  userId                Int           @unique
  equipmentType         String?
  equipmentCategoryId   Int?
  selectedCommissionBps Int?
  truckCurrentLocation  String?
  companyName           String?
  mcDot                  String?
  assignedConsultantId  Int?
  accountStatus         TruckerStatus @default(LEAD)
  activatedAt           DateTime?
  preferredLanes        String?       @db.Text
  avoidedLanes          String?       @db.Text
  factoringCompany      String?
  insuranceStatus       String?
  availability          String?
  mainProblem           String?       @db.Text
  packageType           String?
  billingMethod         BillingMethod @default(FIXED)
  ratePercentageBps     Int?
  profileCompletedAt    DateTime?
  onboardingCompletedAt DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedConsultant    User?         @relation("AssignedConsultant", fields: [assignedConsultantId], references: [id], onDelete: SetNull)
  equipmentCategory     EquipmentCategory? @relation(fields: [equipmentCategoryId], references: [id], onDelete: SetNull)
  lead                  Lead?
  conversations         Conversation[]
  documentRequests      DocumentRequest[]
  documents             Document[]
  invoices              Invoice[]
  payments              Payment[]
  agreements            Agreement[]
  loads                 Load[]

  @@index([assignedConsultantId])
  @@index([equipmentCategoryId])
}

model Lead {
  id               Int        @id @default(autoincrement())
  truckerId        Int        @unique
  source           String     @default("PUBLIC_SIGNUP")
  signupAt         DateTime   @default(now())
  assignedToId     Int?
  assignedAt       DateTime?
  assignmentMethod String?
  sequencePosition Int?
  currentStatus    LeadStatus @default(LEAD_SIGNED_UP)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  trucker          TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)
  assignedTo       User?          @relation("AssignedLeadConsultant", fields: [assignedToId], references: [id], onDelete: SetNull)
  histories        LeadStatusHistory[]

  @@index([assignedToId])
  @@index([currentStatus])
}

model LeadStatusHistory {
  id        Int        @id @default(autoincrement())
  leadId    Int
  status    LeadStatus
  changedBy Int?
  note      String?
  createdAt DateTime   @default(now())

  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model Conversation {
  id                       Int      @id @default(autoincrement())
  truckerId                Int
  consultantId             Int
  lastMessageAt            DateTime?
  twoSidedContactValidated Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  trucker                  TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)
  consultant               User           @relation("ConversationConsultant", fields: [consultantId], references: [id], onDelete: Cascade)
  messages                 Message[]

  @@unique([truckerId, consultantId])
  @@index([consultantId, lastMessageAt])
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int
  senderId       Int
  body           String   @db.Text
  sentAt         DateTime @default(now())
  readAt         DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  attachments    MessageAttachment[]

  @@index([conversationId, sentAt])
}

model MessageAttachment {
  id           Int            @id @default(autoincrement())
  messageId    Int
  uploadedById Int
  kind         AttachmentKind
  originalName String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime       @default(now())

  message      Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader     User           @relation("MessageAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model DocumentRequest {
  id           Int            @id @default(autoincrement())
  truckerId    Int
  requestedBy  Int
  type         String
  instructions String?        @db.Text
  dueDate      DateTime?
  status       DocumentStatus @default(REQUESTED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  trucker      TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)
  requester    User           @relation("DocumentRequester", fields: [requestedBy], references: [id])
  document     Document?

  @@unique([truckerId, type])
}

model Document {
  id                 Int            @id @default(autoincrement())
  truckerId          Int
  documentRequestId  Int?           @unique
  relatedLoadId      Int?
  type               String
  documentTitle      String?
  documentNumber     String?
  issuingAuthority   String?
  issueDate          DateTime?
  originalName       String
  storagePath        String
  mimeType           String
  sizeBytes          Int
  status             DocumentStatus @default(UPLOADED)
  uploadedById       Int
  reviewedById       Int?
  reviewNotes        String?        @db.Text
  expiresAt          DateTime?
  notes              String?        @db.Text
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  trucker            TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)
  request            DocumentRequest? @relation(fields: [documentRequestId], references: [id], onDelete: SetNull)
  relatedLoad        Load?          @relation("GeneralLoadDocument", fields: [relatedLoadId], references: [id], onDelete: SetNull)
  uploader           User           @relation("DocumentUploader", fields: [uploadedById], references: [id])
  reviewer           User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([truckerId, type])
  @@index([relatedLoadId])
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  truckerId     Int
  consultantId  Int
  amountCents   Int
  currency      String        @default("USD")
  description   String
  notes         String?       @db.Text
  status        InvoiceStatus @default(DRAFT)
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  paidAt        DateTime?
  isFirstInvoice Boolean      @default(false)
  agingStartsAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  trucker       TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)
  consultant    User           @relation("InvoiceConsultant", fields: [consultantId], references: [id])
  items         InvoiceItem[]
  payment       Payment?
  agreement     Agreement?

  @@index([truckerId, status])
  @@index([consultantId, status])
}

model InvoiceItem {
  id          Int    @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Int    @default(1)
  unitCents   Int
  totalCents  Int

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id                    Int           @id @default(autoincrement())
  invoiceId             Int           @unique
  truckerId             Int
  amountCents           Int
  processorFeeCents     Int           @default(0)
  dispatcherCommissionCents Int       @default(0)
  refundCents           Int           @default(0)
  creditCents           Int           @default(0)
  companyNetCents       Int
  paymentMethod         String?
  transactionId         String        @unique
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  receiptNumber         String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  invoice               Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  trucker               TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)

  @@index([truckerId, status])
}

model Agreement {
  id                 Int      @id @default(autoincrement())
  truckerId          Int
  invoiceId          Int      @unique
  version            String   @default("1.0")
  signerName         String
  acceptanceCode     String   @unique
  signedAt           DateTime @default(now())
  ipAddress          String?
  deviceInfo         String?  @db.Text
  createdAt          DateTime @default(now())

  trucker            TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)
  invoice            Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Load {
  id             Int        @id @default(autoincrement())
  truckerId      Int
  consultantId   Int
  loadRef        String     @unique
  pickupLocation String
  pickupAt       DateTime?
  deliveryLocation String
  deliveryAt     DateTime?
  rateCents      Int
  broker         String?
  status         LoadStatus @default(DRAFT)
  notes          String?    @db.Text
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  trucker        TruckerProfile @relation(fields: [truckerId], references: [id], onDelete: Cascade)
  consultant     User           @relation("LoadConsultant", fields: [consultantId], references: [id])
  documents      LoadDocument[]
  generalDocuments Document[]   @relation("GeneralLoadDocument")

  @@index([truckerId, status])
  @@index([consultantId, status])
}

model LoadDocument {
  id           Int      @id @default(autoincrement())
  loadId       Int
  type         String
  originalName String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  uploadedById Int
  createdAt    DateTime @default(now())

  load         Load     @relation(fields: [loadId], references: [id], onDelete: Cascade)
  uploader     User     @relation(fields: [uploadedById], references: [id])

  @@index([loadId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    Int
  title     String
  message   String   @db.Text
  url       String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}


model EquipmentCategory {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  description    String?  @db.Text
  commissionBps  Int      @default(500)
  isActive       Boolean  @default(true)
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  truckers       TruckerProfile[]

  @@index([isActive, displayOrder])
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

