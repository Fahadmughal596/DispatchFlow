/* ===== Mobile sidebar reliability + Super Admin support ===== */
.mobile-menu-button {
  position: relative;
  z-index: 150;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
  pointer-events: auto;
}

@media (max-width: 900px) {
  .sidebar {
    visibility: hidden;
    pointer-events: none;
    will-change: transform;
  }

  .sidebar.open {
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-sidebar-backdrop {
    display: block;
  }
}

.support-page-grid {
  align-items: start;
}

.support-info-card {
  position: sticky;
  top: 92px;
}

.support-info-list {
  display: grid;
  gap: 14px;
}

.support-info-list > div {
  display: grid;
  grid-template-columns: 34px minmax(0, 1fr);
  gap: 12px;
  align-items: center;
  padding: 13px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(255,255,255,.025);
}

.support-info-list strong {
  width: 34px;
  height: 34px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  color: #fff;
  background: rgba(20,119,255,.2);
  border: 1px solid rgba(20,119,255,.35);
}

.support-info-list span {
  color: var(--muted);
  font-size: 13px;
}

@media (max-width: 840px) {
  .support-page-grid {
    grid-template-columns: 1fr;
  }

  .support-info-card {
    position: static;
  }
}

