.profile-popup-card{position:relative;width:min(920px,100%);max-height:calc(100vh - 48px);overflow:auto;padding:28px;border-color:rgba(54,198,232,.32);box-shadow:0 28px 90px rgba(0,0,0,.55)}
.profile-popup-close{position:absolute;right:16px;top:14px;width:38px;height:38px;border-radius:10px;border:1px solid var(--line);background:rgba(255,255,255,.055);color:#fff;font-size:25px;line-height:1}
.profile-popup-heading{padding-right:48px;margin-bottom:20px}.profile-popup-heading h2{font-size:32px;letter-spacing:-.035em;margin:14px 0 6px}.profile-popup-heading p{color:var(--muted);margin:0;max-width:720px}
